generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MODULE 00 — Price Catalog & Estimating
// ─────────────────────────────────────────────

enum ResourceType {
  material
  labor
  equipment
  transport
  subcontract
}

model Resource {
  id          String          @id @default(uuid())
  code        String          @unique
  description String
  unit        String
  type        ResourceType
  category    String
  active      Boolean         @default(true)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  prices      ResourcePrice[]
  apuLines    APULine[]
  commitments Commitment[]
  costItems   CostItem[]
}

enum PriceSourceType {
  internal
  camacol
  gobernacion
  supplier
  manual
}

model ResourcePrice {
  id          String          @id @default(uuid())
  resourceId  String
  sourceType  PriceSourceType
  sourceName  String
  price       Decimal         @db.Decimal(15, 2)
  currency    String          @default("COP")
  validFrom   DateTime
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime        @default(now())

  resource    Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model APUItem {
  id                String     @id @default(uuid())
  code              String     @unique
  description       String
  outputUnit        String
  category          String
  aiuAdminPct       Decimal    @default(10) @db.Decimal(5, 2)
  aiuContingencyPct Decimal    @default(5)  @db.Decimal(5, 2)
  aiuProfitPct      Decimal    @default(3)  @db.Decimal(5, 2)
  active            Boolean    @default(true)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  lines             APULine[]
  costItems         CostItem[]
}

model APULine {
  id             String   @id @default(uuid())
  apuItemId      String
  resourceId     String
  quantity       Decimal  @db.Decimal(12, 4)
  wasteFactorPct Decimal  @default(0) @db.Decimal(5, 2)
  order          Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())

  apuItem        APUItem  @relation(fields: [apuItemId], references: [id], onDelete: Cascade)
  resource       Resource @relation(fields: [resourceId], references: [id])
}

// ─────────────────────────────────────────────
// MODULE 01 — Projects
// ─────────────────────────────────────────────

enum ProjectType {
  architecture
  construction
  civil
  design_build
}

enum ProjectStatus {
  prospect
  design
  permitting
  execution
  closeout
  closed
}

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  type        ProjectType
  status      ProjectStatus @default(prospect)
  description String?
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  clientId       String?
  client         Client?         @relation(fields: [clientId], references: [id])
  costItems      CostItem[]
  commitments    Commitment[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
}

// ─────────────────────────────────────────────
// MODULE 02 — Billing / AR
// ─────────────────────────────────────────────

enum PaymentTermType {
  net30
  net60
  net90
  fixed_day
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

model Client {
  id              String          @id @default(uuid())
  name            String
  taxId           String?         @unique
  email           String?
  phone           String?
  address         String?
  contactName     String?
  paymentTermType PaymentTermType @default(net30)
  fixedDay        Int?
  notes           String?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  projects        Project[]
  purchaseOrders  PurchaseOrder[]
  invoices        Invoice[]
}

model PurchaseOrder {
  id        String   @id @default(uuid())
  number    String
  clientId  String
  projectId String
  amount    Decimal  @db.Decimal(15, 2)
  issueDate DateTime
  notes     String?
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@unique([clientId, number])
}

model Invoice {
  id              String        @id @default(uuid())
  number          String        @unique
  internalRef     String        @unique
  clientId        String
  projectId       String
  purchaseOrderId String?
  status          InvoiceStatus @default(draft)
  issueDate       DateTime
  dueDate         DateTime
  subtotal        Decimal       @db.Decimal(15, 2)
  taxPct          Decimal       @default(19) @db.Decimal(5, 2)
  taxAmount       Decimal       @db.Decimal(15, 2)
  total           Decimal       @db.Decimal(15, 2)
  description     String
  notes           String?
  sentAt          DateTime?
  paidAt          DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client        Client         @relation(fields: [clientId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
}

model InvoiceSequence {
  year    Int @id
  lastSeq Int @default(0)
}

// ─────────────────────────────────────────────
// MODULE 03 — Budget & Execution
// ─────────────────────────────────────────────

enum CostCategory {
  labor
  materials
  equipment
  subcontractor
  design_fees
  admin_permits
  transport
  other
}

model CostItem {
  id               String       @id @default(uuid())
  projectId        String
  apuItemId        String?
  resourceId       String?
  category         CostCategory
  description      String
  unit             String
  quantityBudgeted Decimal      @db.Decimal(12, 4)
  unitCostBudgeted Decimal      @db.Decimal(15, 2)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apuItem          APUItem?     @relation(fields: [apuItemId], references: [id])
  resource         Resource?    @relation(fields: [resourceId], references: [id])
  commitments      Commitment[]
}

model Commitment {
  id             String       @id @default(uuid())
  projectId      String
  costItemId     String
  resourceId     String?
  description    String
  date           DateTime
  totalCommitted Decimal      @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costItem       CostItem     @relation(fields: [costItemId], references: [id], onDelete: Cascade)
  resource       Resource?    @relation(fields: [resourceId], references: [id])
  payments       Payment[]
}

model Payment {
  id           String     @id @default(uuid())
  commitmentId String
  date         DateTime
  amount       Decimal    @db.Decimal(15, 2)
  notes        String?
  createdAt    DateTime   @default(now())

  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}
