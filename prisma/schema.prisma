generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MODULE 00 — Price Catalog & Estimating
// ─────────────────────────────────────────────

enum ResourceType {
  material
  labor
  equipment
  transport
  subcontract
}

model Resource {
  id          String          @id @default(uuid())
  code        String          @unique
  description String
  unit        String
  type        ResourceType
  category    String
  active      Boolean         @default(true)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  prices      ResourcePrice[]
  apuLines    APULine[]
  commitments Commitment[]
  costItems   CostItem[]
}

enum PriceSourceType {
  internal
  camacol
  gobernacion
  supplier
  manual
}

model ResourcePrice {
  id          String          @id @default(uuid())
  resourceId  String
  sourceType  PriceSourceType
  sourceName  String
  price       Decimal         @db.Decimal(15, 2)
  currency    String          @default("COP")
  validFrom   DateTime
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime        @default(now())

  resource    Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model APUItem {
  id                String     @id @default(uuid())
  code              String     @unique
  description       String
  outputUnit        String
  category          String
  aiuAdminPct       Decimal    @default(10) @db.Decimal(5, 2)
  aiuContingencyPct Decimal    @default(5)  @db.Decimal(5, 2)
  aiuProfitPct      Decimal    @default(3)  @db.Decimal(5, 2)
  active            Boolean    @default(true)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  lines             APULine[]
  costItems         CostItem[]
}

model APULine {
  id             String   @id @default(uuid())
  apuItemId      String
  resourceId     String
  quantity       Decimal  @db.Decimal(12, 4)
  wasteFactorPct Decimal  @default(0) @db.Decimal(5, 2)
  order          Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())

  apuItem        APUItem  @relation(fields: [apuItemId], references: [id], onDelete: Cascade)
  resource       Resource @relation(fields: [resourceId], references: [id])
}

// ─────────────────────────────────────────────
// MODULE 01 — Projects
// ─────────────────────────────────────────────

enum ProjectType {
  architecture
  construction
  civil
  design_build
}

enum ProjectStatus {
  prospect
  design
  permitting
  execution
  closeout
  closed
}

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  type        ProjectType
  status      ProjectStatus @default(prospect)
  description String?
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  costItems   CostItem[]
  commitments Commitment[]
}

// ─────────────────────────────────────────────
// MODULE 03 — Budget & Execution
// ─────────────────────────────────────────────

enum CostCategory {
  labor
  materials
  equipment
  subcontractor
  design_fees
  admin_permits
  transport
  other
}

model CostItem {
  id               String       @id @default(uuid())
  projectId        String
  apuItemId        String?
  resourceId       String?
  category         CostCategory
  description      String
  unit             String
  quantityBudgeted Decimal      @db.Decimal(12, 4)
  unitCostBudgeted Decimal      @db.Decimal(15, 2)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  apuItem          APUItem?     @relation(fields: [apuItemId], references: [id])
  resource         Resource?    @relation(fields: [resourceId], references: [id])
  commitments      Commitment[]
}

model Commitment {
  id             String       @id @default(uuid())
  projectId      String
  costItemId     String
  resourceId     String?
  description    String
  date           DateTime
  totalCommitted Decimal      @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costItem       CostItem     @relation(fields: [costItemId], references: [id], onDelete: Cascade)
  resource       Resource?    @relation(fields: [resourceId], references: [id])
  payments       Payment[]
}

model Payment {
  id           String     @id @default(uuid())
  commitmentId String
  date         DateTime
  amount       Decimal    @db.Decimal(15, 2)
  notes        String?
  createdAt    DateTime   @default(now())

  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
}
